#!/usr/bin/env bash

GLOBAL_GITIGNORE_PATH=${HOME}/.gitignore
SHELLS_BASE_PATH=${HOME}/dots:${HOME}/Avito/shells
HOOKS_PATH=${HOME}/.config/lefthook

SYSTEM=${SYSTEM:-$(nix eval --raw --impure --expr builtins.currentSystem 2>/dev/null || echo aarch64-darwin)}

usage() {
	echo "project <command> <params>"

	echo -e "\tinit <shell>"
	echo -e "\tclean"
	echo -e "\tnix"
	IFS=: read -r -d '' -a path_array < <(printf '%s:\0' "$SHELLS_BASE_PATH")
	for p in "${path_array[@]}"; do
		nix flake show "$p" --json 2>/dev/null | jq -r "(.devShells.\"${SYSTEM}\" // {}) | keys[]" | sed 's/^\(.*\)$/\t\t\1/'
	done
	echo

	echo -e "\thook"
	IFS=: read -r -d '' -a path_array < <(printf '%s:\0' "$HOOKS_PATH")
	for p in "${path_array[@]}"; do
		[[ -d "$p" ]] || continue
		find "$p" -name '*.yml' -exec basename {} .yml \; | sed 's/^/\t\t/' | sort
	done
	exit 1
}

gitignore() {
	touch "$GLOBAL_GITIGNORE_PATH"

	git config --get core.excludesfile | grep -Fxq "$GLOBAL_GITIGNORE_PATH" || git config --global core.excludesfile "$GLOBAL_GITIGNORE_PATH"

	grep -Fxq "$1" "$GLOBAL_GITIGNORE_PATH" || echo "$1" >>"$GLOBAL_GITIGNORE_PATH"
}

clean() {
	direnv deny . &>/dev/null
	rm -f .envrc &>/dev/null

	lefthook uninstall &>/dev/null
	rm -f lefthook.yml &>/dev/null
	rm -rf .lefthook
}

shell() {
	local flake=""

	IFS=: read -r -d '' -a path_array < <(printf '%s:\0' "$SHELLS_BASE_PATH")
	for p in "${path_array[@]}"; do
		if nix flake show "$p" --json 2>/dev/null | jq -r "(.devShells.\"${SYSTEM}\" // {}) | keys[]" | grep -Fxq "$1"; then
			flake="$p"
			break
		fi
	done
	[[ "$flake" == "" ]] && echo "Unknown shell $1" && echo && usage

	echo "use flake ${flake}#$1 --impure"
	echo "use flake ${flake}#\\\"$1\\\" --impure" >.envrc

	echo direnv allow .
	direnv allow .

	gitignore .direnv
	gitignore .envrc
}

hook() {
	local p
	local dirs=()

	IFS=: read -r -d '' -a path_array < <(printf '%s:\0' "$HOOKS_PATH")
	for p in "${path_array[@]}"; do
		[[ -d "$p" ]] && dirs+=("$p")
	done

	if [ "${#dirs[@]}" -eq 0 ]; then
		echo "No hook directories found"
		usage
	fi

	p=$(find "${dirs[@]}" -name "$1.yml" -print -quit)
	[[ "$p" == "" ]] && echo "Unknown hook $1" && usage

	echo "Installing hooks $p"
	cat >lefthook.yml <<EOF
extends:
    - $p
EOF

	echo lefthook install
	lefthook install

	echo ln -s "${HOME}/.bin/hooks" .lefthook
	ln -s "${HOME}/.bin/hooks" .lefthook

	gitignore lefthook.yml
	gitignore .lefthook
}

if [ $# -eq 0 ]; then
	usage
fi

case "$1" in
"init")
	[ $# -eq 2 ] || usage
	clean
	shell "$2"
	hook general
	;;

"nix" | "shell")
	[ $# -eq 2 ] || usage
	shell "$2"
	;;

"hook")
	[ $# -eq 2 ] || usage
	hook "$2"
	;;

"clean")
	[ $# -eq 1 ] || usage
	clean
	;;

*)
	usage
	;;
esac
