#!/usr/bin/env bash

set -euo pipefail

proxy="192.168.1.215:1080"

fail() {
	echo "Usage: proxy <enable|disable|toggle|status>"
	exit 1
}

enable() {
	printf 'export ALL_PROXY=%q\n' "socks5h://$proxy"
	printf 'export http_proxy=%q\n' "socks5h://$proxy"
	printf 'export https_proxy=%q\n' "socks5h://$proxy"
	printf 'export all_proxy=%q\n' "socks5h://$proxy"
}

disable() {
	echo "unset ALL_PROXY http_proxy https_proxy all_proxy"
}

is_enabled() {
	[[ -n "${ALL_PROXY:-}${http_proxy:-}${https_proxy:-}${all_proxy:-}" ]]
}

toggle() {
	if is_enabled; then
		disable
	else
		enable
	fi
}

status() {
	if is_enabled; then
		echo Proxy enabled
	else
		echo Proxy disabled
	fi
}

if [ $# -ne 1 ]; then
	fail
fi

case "$1" in
e | enable)
	enable
	;;
d | disable)
	disable
	;;
t | toggle)
	toggle
	;;
s | status)
	status
	;;
*)
	fail
	;;
esac
