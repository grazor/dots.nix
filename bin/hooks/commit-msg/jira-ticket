#!/usr/bin/env bash

if [ -z "$BRANCHES_TO_SKIP" ]; then
    BRANCHES_TO_SKIP=(master main develop test)
fi

BRANCH_NAME=$(git symbolic-ref --short HEAD)
BRANCH_NAME="${BRANCH_NAME##*/}"
TICKET_NAME=$(printf '%s\n' "$BRANCH_NAME" | grep -Eo '[A-Z][A-Z0-9]+-[0-9]+' | head -n 1)

# branch without an issue
[[ "$TICKET_NAME" == "" ]] && exit 0

# skip branch
printf "%s\n" "${BRANCHES_TO_SKIP[@]}" | grep -Fxq "$BRANCH_NAME" && exit 0

# issue already present
grep -q "^\[$TICKET_NAME\]" "$1" && exit 0

# incorrect issue number
grep -Eq "^\[[A-Z][A-Z0-9]+-[0-9]+\]" "$1" && echo Invalid ticket number present && exit 1

echo Commit message has been fixed
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
awk -v ticket="$TICKET_NAME" 'NR == 1 { $0 = "[" ticket "] " $0 } { print }' "$1" >"$tmp"
mv "$tmp" "$1"
trap - EXIT
